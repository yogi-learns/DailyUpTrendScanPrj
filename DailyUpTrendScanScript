// Send msg on telegram
function sendTelegram(text) {
  const url = "https://api.telegram.org/bot" + TG_TOKEN + "/sendMessage";
  const payload = {
    chat_id: TG_CHAT_ID,
    text: text,
    parse_mode: "HTML"
  };

  const params = {
    method: "post",
    contentType: "application/json",
    payload: JSON.stringify(payload),
    muteHttpExceptions: true
  };

  UrlFetchApp.fetch(url, params);
}

/**
 * STEP 1 — Build historical OHLC blocks in HIST sheet for each symbol.
 * The blocks allow reliable EMA and Heiken-Ashi calculations.
 */

function populateHistoryBlocks() {
  console.log('Starting populateHistoryBlocks function');
  const ss = SpreadsheetApp.getActive();
  const main = ss.getSheetByName('Main');
  let hist = ss.getSheetByName('HIST');
  if (!hist) hist = ss.insertSheet('HIST');
  hist.clear();

  const symbols = main.getRange('A2:A').getValues()
    .map(r => r[0])
    .filter(v => v && typeof v === 'string');

  const DAYS = 140;
  const GAP = 2;

  for (let i = 0; i < symbols.length; i++) {
    const sym = symbols[i];
    const rowStart = 1 + i * (DAYS + 3 + GAP);

    hist.getRange(rowStart, 1).setValue(sym);
    hist.getRange(rowStart + 2, 1).setFormula(
      `=IFERROR(GOOGLEFINANCE("NSE:${sym}","open",TODAY()-${DAYS},TODAY()),)`
    );
    hist.getRange(rowStart + 2, 3).setFormula(
      `=IFERROR(GOOGLEFINANCE("NSE:${sym}","high",TODAY()-${DAYS},TODAY()),)`
    );
    hist.getRange(rowStart + 2, 5).setFormula(
      `=IFERROR(GOOGLEFINANCE("NSE:${sym}","low",TODAY()-${DAYS},TODAY()),)`
    );
    hist.getRange(rowStart + 2, 7).setFormula(
      `=IFERROR(GOOGLEFINANCE("NSE:${sym}","close",TODAY()-${DAYS},TODAY()),)`
    );
  }

 for (let i = 0; i < symbols.length; i++) {
    const sym = symbols[i];
    const rowStart = 1 + i * (DAYS + 3 + GAP);

    hist.getRange(rowStart + 2 + DAYS, 2).setFormula(
      `=IFERROR(GOOGLEFINANCE("NSE:${sym}","priceopen"),)`
    );
    hist.getRange(rowStart + 2 + DAYS, 4).setFormula(
      `=IFERROR(GOOGLEFINANCE("NSE:${sym}","high"),)`
    );
    hist.getRange(rowStart + 2 + DAYS, 6).setFormula(
      `=IFERROR(GOOGLEFINANCE("NSE:${sym}","low"),)`
    );
    hist.getRange(rowStart + 2 + DAYS, 8).setFormula(
      `=IFERROR(GOOGLEFINANCE("NSE:${sym}","price"),)`
    );
 };

  //SpreadsheetApp.getUi().alert("Historical blocks created in HIST sheet.");
}

/**
 * Utility: Compute EMA for an array of numbers.
 */
function computeEMA(values, period) {
  if (!values || values.length === 0) return null;
  const k = 2 / (period + 1);
  let ema = values[0];
  for (let i = 1; i < values.length; i++) {
    ema = values[i] * k + ema * (1 - k);
  }
  return Math.round(ema * 100) / 100;
}

function setQueryFormula(targetSheetName, targetRangeA1, sourceSheetName, sourceRangeA1, querySQL, headers = 1) {

  const ss = SpreadsheetApp.getActive();
  const targetSheet = ss.getSheetByName(targetSheetName);
  const sourceSheet = ss.getSheetByName(sourceSheetName);

  if (!targetSheet) throw new Error(`Target sheet "${targetSheetName}" not found.`);
  if (!sourceSheet) throw new Error(`Source sheet "${sourceSheetName}" not found.`);

  // Build final QUERY formula string
  const formula =
    `=QUERY(${sourceSheetName}!${sourceRangeA1}, "${querySQL}", ${headers})`;

  // Write the formula
  targetSheet.getRange(targetRangeA1).setFormula(formula);
}

/**
 * Clears all rows from A5:C down to the last used row.
 *
 * @param {string} sheetName - Name of the sheet to clear
 */
function clearSheet(sheetName) {

  const ss = SpreadsheetApp.getActive();
  const sh = ss.getSheetByName(sheetName);
  sh.clear();
}

function createBuyListQuery() {
  clearSheet("SendTelegramTable");
  setQueryFormula(
